# .env.example — local dev defaults for docker-compose.
# Copy to .env (gitignored) and adjust as needed.
# All values have sensible defaults in docker-compose.yml, so this file
# is OPTIONAL: the stack will run with `make up` even without a .env.

# Postgres
POSTGRES_USER=unifleet
POSTGRES_PASSWORD=unifleet_dev_pw
POSTGRES_DB=unifleet

# App
BASE_URL=http://localhost:5000
PORT=5000
PERSISTENCE_BACKEND=csv
DATABASE_URL=postgresql://unifleet:unifleet_dev_pw@db:5432/unifleet

# Auth
SUPPLIER_API_TOKEN=unifleet2025mvp
# ADMIN_KEY: legacy ?key= / X-Admin-Key fallback. No default — key auth is
# DISABLED unless set. Set in prod (and staging).
ADMIN_KEY=unifleet-admin
# ADMIN_PASSWORD: password for the /admin/login session. Login is disabled
# unless set. REQUIRED in prod/staging or admins cannot log in.
ADMIN_PASSWORD=change-me
# SECRET_KEY: signs the session cookie. REQUIRED in prod — a stable value
# keeps sessions valid across restarts. Random per-process fallback in dev.
SECRET_KEY=dev-only-change-me
